#!/data/data/com.termux/files/usr/bin/bash
# Atajo para test_sdl2_sprite_debug
# Este script configura la GPU y lanza el test automáticamente

cd /data/data/com.termux/files/home/shield-project

# Configurar GPU
export DISPLAY=:0
export MESA_LOADER_DRIVER_OVERRIDE=zink
export DRI3=1

# Lanzar test
./target/release/test_sdl2_sprite_debug
